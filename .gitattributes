# Auto detect text files and perform LF normalization
* text=auto

# The above is the standard text=auto attribute which will:
# - Normalize line endings to LF on commit for text files
# - Keep binary files untouched

# Explicitly declare text files you want to always be normalized and converted
*.sh eol=lf
*.py eol=lf
*.md eol=lf
*.json eol=lf
*.yml eol=lf
*.yaml eol=lf
*.toml eol=lf
*.cfg eol=lf
*.ini eol=lf
*.txt eol=lf
*.diff eol=lf
*.patch eol=lf

# C/C++ source code should use LF line endings
*.c eol=lf
*.cpp eol=lf
*.h eol=lf
*.hpp eol=lf
*.cc eol=lf
*.hh eol=lf

# Shell scripts must have Unix line endings
*.sh eol=lf text=eol=lf

# Binary files that should not be modified
*.bin binary
*.exe binary
*.dll binary
*.so binary
*.a binary
*.dylib binary
*.metallib binary

# Model files - treat as binary, no normalization
*.gguf binary
*.gguf.json binary

# Git LFS for large model files (if needed in future)
# *.gguf filter=lfs diff=lfs merge=lfs -text
