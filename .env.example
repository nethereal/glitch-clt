# glitch-CLT — Environment Configuration
# ========================================
# Copy this file to .env.local and customize for your setup:
#   cp .env.example .env.local
#
# All variables are optional with sensible defaults shown below.

# --- Model Configuration ---

# Path to GGUF models directory (relative to docker-compose.yml)
MODEL_PATH=./models

# Filename of the model to load
MODEL_FILE=Qwen3.6-35B-A3B-UD-IQ4_XS.gguf

# --- Server Configuration ---

# Port the server exposes on the host machine
LLAMACPP_PORT=9998

# Maximum context window size in tokens
# TurboQuant turbo4 compression enables up to 262K tokens within VRAM limits
CONTEXT_SIZE=262144

# --- Inference Parameters (optional overrides) ---

# Temperature: controls randomness (0.0 = deterministic, 1.0 = creative)
# LLAMA_TEMP=0.6

# Top-p nucleus sampling threshold
# LLAMA_TOP_P=0.95

# Top-K sampling cutoff
# LLAMA_TOP_K=20

# Minimum probability threshold
# LLAMA_MIN_P=0.0

# Repetition penalty (>1.0 reduces repetition)
# LLAMA_REPEAT_PENALTY=1.1

# Number of CPU threads for CPU fallback operations
# LLAMA_THREADS=8

# Batch size for inference
# LLAMA_BATCH_SIZE=256

# --- TurboQuant Mode ---

# KV cache compression type: turbo2, turbo3, or turbo4
# turbo4 = 4-bit PolarQuant (~8x VRAM savings on K/V caches)
# LLAMA_CACHE_TYPE_K=turbo4
# LLAMA_CACHE_TYPE_V=turbo4
MODEL_PATH=./models
MODEL_FILE=Qwen3.6-35B-A3B-UD-IQ4_XS.gguf
LLAMACPP_PORT=9998
CONTEXT_SIZE=262144
